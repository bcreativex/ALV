CLASS lcl_alv DEFINITION.
  PUBLIC SECTION.
    DATA: gt_fcat TYPE lvc_t_fcat.  " Field Catalog for ALV

    METHODS:
      build_fcat,    " Build ALV column definations
      handle_hotspot_click   " NAVIGATE TO XD02 Text tab
                  FOR EVENT hotspot_click OF cl_gui_alv_grid
        IMPORTING e_row_id e_column_id,

      handle_toolbar   " Download Button to ALV bar
                  FOR EVENT toolbar OF cl_gui_alv_grid
        IMPORTING e_object e_interactive,
      handle_user_command   " Handle Download button Click
                  FOR EVENT user_command OF cl_gui_alv_grid
        IMPORTING e_ucomm.

ENDCLASS.

CLASS lcl_main DEFINITION.
  PUBLIC SECTION.
    METHODS: run.  " Main execution Method
ENDCLASS.

