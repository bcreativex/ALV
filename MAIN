  c_tdobject       TYPE stxh-tdobject VALUE 'KNA1',

  c_tcode_xd02     TYPE syucomm VALUE 'XD02', " Customer change transaction
  c_fcode_download TYPE syucomm VALUE 'DOWNLOAD', " Download button function code

  c_prog_sapmf02d  TYPE bdcdata-program VALUE 'SAPMF02D', " XD02 program name
  c_screen_0101    TYPE bdcdata-dynpro VALUE '0101', " XD02 initial screen
  c_screen_0110    TYPE bdcdata-dynpro VALUE '0110', " XD02 general data screen
  c_bdc_cursor     TYPE bdcdata-fnam VALUE 'BDC_CURSOR', " BDC cursor field
  c_bdc_okcode     TYPE bdcdata-fnam VALUE 'BDC_OKCODE', " BDC ok-code field
  c_rf02d_kunnr    TYPE bdcdata-fnam VALUE 'RF02D-KUNNR', " Customer number field
  c_rf02d_d0110    TYPE bdcdata-fnam VALUE 'RF02D-D0110', " Address checkbox field
  c_kna1_name1     TYPE bdcdata-fnam VALUE 'KNA1-NAME1', " Customer name field
  c_okcode_enter   TYPE bdcdata-fval VALUE '/00', " Enter/confirm ok-code
  c_okcode_text    TYPE bdcdata-fval VALUE '=TEXT', " Extras → Texts ok-code
  c_dynbegin_x     TYPE bdcdata-dynbegin VALUE 'X', " BDC screen begin flag

  c_filetype       TYPE string VALUE 'ASC', " ASCII file type
  c_separator      TYPE char01 VALUE 'X', " Write field separator
  c_file_prefix    TYPE string VALUE 'customer_texts_', " Default filename prefix
  c_file_ext       TYPE string VALUE '.txt', " Default file extension

  c_save_layout    TYPE char01 VALUE 'A', " Allow layout save
  c_container      TYPE scrfname VALUE 'CONTAINER', " Screen container name

  c_mode           TYPE char01 VALUE 'A',
  c_w              TYPE char01 VALUE 'W',
  c_s              TYPE char01 VALUE 'S',

