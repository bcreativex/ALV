TABLES: kna1, stxh, knvv, ttxit.

"----------------------------------------------------------------------
" OUTPUT STRUCTURE — one row per TDLINE (FDS requirement)
"----------------------------------------------------------------------
TYPES: BEGIN OF ty_output,
         kunnr  TYPE kna1-kunnr, " Customer Number
         name1  TYPE kna1-name1, " Customer Name
         tdid   TYPE stxh-tdid,  " Text Type ID
         tdtext TYPE ttxit-tdtext, " Text ID description from TTXIT
         spras  TYPE stxh-tdspras, " Language Key
         tdline TYPE tline-tdline, " One row per line (132 chars fixed)
       END OF ty_output.

TYPES: tty_output TYPE STANDARD TABLE OF ty_output WITH DEFAULT KEY.

