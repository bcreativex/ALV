  c_fcode_exit     TYPE syucomm VALUE 'EXIT', " Exit button
  c_fcode_cancel   TYPE syucomm VALUE 'CANCEL', " Cancel button

  c_pf_status      TYPE sypfkey VALUE 'ZALV_STATUS', " ALV screen PF status
  c_titlebar       TYPE syrepid VALUE 'TITLE100', " Screen title bar

  c_field_kunnr    TYPE lvc_fname VALUE 'KUNNR', " Customer number field
  c_field_name1    TYPE lvc_fname VALUE 'NAME1', " Customer name field
  c_field_tdid     TYPE lvc_fname VALUE 'TDID', " Text type field
  c_field_tdtext   TYPE lvc_fname VALUE 'TDTEXT', " Text description field
  c_field_spras    TYPE lvc_fname VALUE 'SPRAS', " Language field
  c_field_tdline   TYPE lvc_fname VALUE 'TDLINE'. " Text line field




