*
*  APPEND la_r_salesorg TO r_salesorg.

ENDFORM.                    " ZF_SALESORG_TO_RANGE


*&---------------------------------------------------------------------*
*&      Form  top_of_page
*&---------------------------------------------------------------------*
* To display other criteria fields on TOP-OF-PAGE of ALV report
*----------------------------------------------------------------------*
FORM top_of_page.                                           "#EC CALLED

  DATA:  li_header       TYPE  slis_t_listheader,
         la_header       TYPE  slis_listheader,
         la_ttxit        TYPE  ttxit,
         l_str           TYPE  string,
         li_ttxit        TYPE  TABLE OF ttxit.


* Partner Role
  IF NOT p_role IS INITIAL.
    la_header-typ  = c_select.
    la_header-key  = 'Partner Role:'.
    la_header-info = p_role.

    APPEND la_header TO li_header.
  ENDIF.

* Sales Org
  IF NOT s_eccorg[]  IS INITIAL.
    la_header-typ  = c_select.
    la_header-key  = 'Sales Org:'.
    LOOP AT s_eccorg.
    IF sy-tabix = 1.
    CONCATENATE s_eccorg-low ',' s_eccorg-high INTO l_str.
    la_header-info = l_str.
    ELSE.
    CONCATENATE la_header-info ',' s_eccorg-low ',' s_eccorg-high INTO la_header-info.
    ENDIF.
    CLEAR l_str.
    ENDLOOP.
    APPEND la_header TO li_header.
  ENDIF.

* Customer Class
  IF NOT p_custcl  IS INITIAL.
    la_header-typ  = c_select.
    la_header-key  = 'Customer Class:'.
    la_header-info = p_custcl.

    APPEND la_header TO li_header.
  ENDIF.

* Search Term
  IF NOT p_sort1  IS INITIAL.
    la_header-typ  = c_select.
    la_header-key  = 'Search Term:'.
    la_header-info = p_sort1.

    APPEND la_header TO li_header.
  ENDIF.

* Industry Sector
  IF NOT p_indust  IS INITIAL.
    la_header-typ  = c_select.
    la_header-key  = 'Industry Sector:'.
    la_header-info = p_indust.

    APPEND la_header TO li_header.
  ENDIF.

* Text Types
  IF NOT s_txtid  IS INITIAL.

    CLEAR: la_header.

    SELECT * INTO TABLE li_ttxit
      FROM ttxit WHERE tdspras  = sy-langu
                   AND tdobject = c_bp_tab
                   AND tdid    IN s_txtid.

    la_header-typ  = c_select.
    la_header-key  = 'Text Types:'.

    LOOP AT li_ttxit INTO la_ttxit.

      IF sy-tabix = 1.
        la_header-info = la_ttxit-tdid.
      ELSE.
        CONCATENATE la_header-info ',' space la_ttxit-tdid INTO la_header-info.
      ENDIF.

    ENDLOOP.

    APPEND la_header TO li_header.
  ENDIF.


  CALL FUNCTION 'REUSE_ALV_COMMENTARY_WRITE'
    EXPORTING
      it_list_commentary = li_header.

ENDFORM.                    "top_of_page


*&---------------------------------------------------------------------*
*&      Form  ZF_F4_HELP_TEXT_TYPE
*&---------------------------------------------------------------------*
* F4 help for text id
*----------------------------------------------------------------------*
FORM zf_f4_help_text_type .

  TYPES : BEGIN OF t_text_types,
           tdid   TYPE tdid,
           tdtext TYPE tdtext,
          END   OF t_text_types.

  DATA : li_ttxit        TYPE  TABLE OF t_text_types.


  SELECT tdid tdtext
    INTO TABLE li_ttxit
    FROM ttxit
   WHERE tdspras  = sy-langu
     AND tdobject = c_bp_tab.

  CHECK  li_ttxit IS NOT INITIAL.

* For F4 functionality for text type
  CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
    EXPORTING
      retfield        = 'TDID'
      dynpprog        = sy-repid
      dynpnr          = sy-dynnr
      dynprofield     = 's_txtid'
      value_org       = 'S'
    TABLES
      value_tab       = li_ttxit
    EXCEPTIONS
      parameter_error = 1
      no_values_found = 2
      OTHERS          = 3.

ENDFORM.                    " ZF_F4_HELP_TEXT_TYPE


