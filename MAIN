" Data Declarations
DATA: go_container TYPE REF TO cl_gui_custom_container,
      go_grid      TYPE REF TO cl_gui_alv_grid,
      go_alv_obj   TYPE REF TO lcl_alv, " Global so handler stays alive
      gs_layout    TYPE lvc_s_layo.

*=====================================================================*
* lcl_main IMPLEMENTATION
*=====================================================================*
CLASS lcl_main IMPLEMENTATION.

  METHOD run.

    DATA lv_vkorg TYPE vkorg VALUE '1000'.

    TYPES: BEGIN OF ty_raw,

             kunnr   TYPE kna1-kunnr,
             name1   TYPE kna1-name1,
             tdid    TYPE stxh-tdid,
             tdspras TYPE stxh-tdspras,
             tdname  TYPE stxh-tdname,
           END OF ty_raw.

    DATA: lt_raw    TYPE STANDARD TABLE OF ty_raw,
          ls_raw    TYPE ty_raw,

          lt_ttxit  TYPE STANDARD TABLE OF ttxit,
          ls_ttxit  TYPE ttxit,
          lt_lines  TYPE STANDARD TABLE OF tline,
          ls_line   TYPE tline,
          lv_tdtext TYPE ttxit-tdtext,
          lv_first  TYPE abap_bool.

    "--------------------------------------------------------------------
    " Direct JOIN on STXH — avoids FOR ALL ENTRIES type mismatch
    "--------------------------------------------------------------------
    SELECT a~kunnr, a~name1, c~tdid, c~tdspras, c~tdname
    INTO CORRESPONDING FIELDS OF TABLE @lt_raw
    FROM kna1 AS a
    INNER JOIN knvv AS b ON b~kunnr = a~kunnr
    INNER JOIN stxh AS c ON c~tdname = a~kunnr
    WHERE b~vkorg = @lv_vkorg
    AND c~tdobject = @c_tdobject
    AND c~tdspras = @sy-langu.

    IF lt_raw IS INITIAL.
      MESSAGE : s038(zprd) DISPLAY LIKE c_w.
      RETURN.
    ENDIF.

    "--------------------------------------------------------------------

    " Get text descriptions from TTXIT
    "--------------------------------------------------------------------
    SELECT tdid tdtext
    INTO CORRESPONDING FIELDS OF TABLE lt_ttxit

    FROM ttxit
    WHERE tdobject = c_tdobject
    AND tdspras = sy-langu.

    "--------------------------------------------------------------------
    " READ_TEXT — one output row per TDLINE
    "--------------------------------------------------------------------
    CLEAR gy_output.

    SORT lt_raw BY kunnr ASCENDING tdid ASCENDING.

    LOOP AT lt_raw INTO ls_raw.

      READ TABLE lt_ttxit INTO ls_ttxit
      WITH KEY tdid = ls_raw-tdid.
      IF sy-subrc = 0.
        lv_tdtext = ls_ttxit-tdtext.
      ELSE.
        lv_tdtext = ls_raw-tdid.
      ENDIF.


      CLEAR lt_lines.
      CALL FUNCTION 'READ_TEXT'
        EXPORTING
          id       = ls_raw-tdid
          language = ls_raw-tdspras
          name     = ls_raw-tdname
          object   = c_tdobject
        TABLES
          lines    = lt_lines
        EXCEPTIONS
          OTHERS   = 8.

      IF lt_lines IS NOT INITIAL.
        lv_first = abap_true.

        LOOP AT lt_lines INTO ls_line.
          IF ls_line-tdline IS NOT INITIAL.

            CLEAR gs_output.
            IF lv_first = abap_true.
              gs_output-kunnr = ls_raw-kunnr.
              gs_output-name1 = ls_raw-name1.
              gs_output-tdid = ls_raw-tdid.
              gs_output-tdtext = lv_tdtext.
              gs_output-spras = ls_raw-tdspras.
              lv_first = abap_false.
            ENDIF.
            gs_output-tdline = ls_line-tdline.
            APPEND gs_output TO gy_output.

          ENDIF.
        ENDLOOP.
      ENDIF.

    ENDLOOP.
  ENDMETHOD.


ENDCLASS.

*=====================================================================*
* lcl_alv IMPLEMENTATION
*=====================================================================*
CLASS lcl_alv IMPLEMENTATION.

  METHOD build_fcat.
    DATA ls_fc TYPE lvc_s_fcat.
    CLEAR gt_fcat.

    " KUNNR — hotspot column
    CLEAR ls_fc.
    ls_fc-fieldname = c_field_kunnr.
    ls_fc-coltext = text-004.
    ls_fc-outputlen = 10.
    ls_fc-hotspot = abap_true.
    ls_fc-key = abap_true. " Freeze on scroll
    APPEND ls_fc TO gt_fcat.

    " NAME1
    CLEAR ls_fc.
    ls_fc-fieldname = c_field_name1.
    ls_fc-coltext = text-005.
    ls_fc-outputlen = 35.
    APPEND ls_fc TO gt_fcat.

    " TDID
    CLEAR ls_fc.
    ls_fc-fieldname = c_field_tdid.
    ls_fc-coltext = text-006.
    ls_fc-outputlen = 8.
    APPEND ls_fc TO gt_fcat.

    " TDTEXT — description from TTXIT
    CLEAR ls_fc.
    ls_fc-fieldname = c_field_tdtext.
    ls_fc-coltext = text-007.
    ls_fc-outputlen = 30.
    APPEND ls_fc TO gt_fcat.

    " SPRAS
    CLEAR ls_fc.
    ls_fc-fieldname = c_field_spras.
    ls_fc-coltext = text-008.
    ls_fc-outputlen = 5.
    APPEND ls_fc TO gt_fcat.

    " TDLINE — actual text content
    CLEAR ls_fc.
    ls_fc-fieldname = c_field_tdline.
    ls_fc-coltext = text-009.
    ls_fc-outputlen = 80.
    APPEND ls_fc TO gt_fcat.

  ENDMETHOD.

  METHOD handle_hotspot_click.

    CHECK e_column_id-fieldname = c_field_kunnr.

    READ TABLE gy_output INTO DATA(ls_row) INDEX e_row_id-index.
    CHECK sy-subrc = 0.
    CHECK ls_row-kunnr IS NOT INITIAL.

    DATA: lt_bdc TYPE TABLE OF bdcdata,
          ls_bdc TYPE bdcdata.

    " Screen 0101 — XD02 initial screen
    CLEAR ls_bdc.
    ls_bdc-program = c_prog_sapmf02d.
    ls_bdc-dynpro = c_screen_0101.
    ls_bdc-dynbegin = c_dynbegin_x.
    APPEND ls_bdc TO lt_bdc.

    CLEAR ls_bdc.
    ls_bdc-fnam = c_bdc_cursor.
    ls_bdc-fval = c_rf02d_kunnr.
    APPEND ls_bdc TO lt_bdc.

    CLEAR ls_bdc.
    ls_bdc-fnam = c_rf02d_kunnr.
    ls_bdc-fval = ls_row-kunnr. " Customer number from clicked row
    APPEND ls_bdc TO lt_bdc.

    CLEAR ls_bdc.
    ls_bdc-fnam = c_rf02d_d0110.  "address checkbox
    ls_bdc-fval = c_dynbegin_x.
    APPEND ls_bdc TO lt_bdc.

    CLEAR ls_bdc.
    ls_bdc-fnam = c_bdc_okcode.
    ls_bdc-fval = c_okcode_enter.
    APPEND ls_bdc TO lt_bdc.

    " Screen 0110 — General Data, navigate to Texts
    CLEAR ls_bdc.
    ls_bdc-program = c_prog_sapmf02d.
    ls_bdc-dynpro = c_screen_0110.
    ls_bdc-dynbegin = c_dynbegin_x.
    APPEND ls_bdc TO lt_bdc.

    CLEAR ls_bdc.
    ls_bdc-fnam = c_bdc_cursor.
    ls_bdc-fval = c_kna1_name1.
    APPEND ls_bdc TO lt_bdc.

    CLEAR ls_bdc.
    ls_bdc-fnam = c_bdc_okcode.
    ls_bdc-fval = c_okcode_text. " Extras → Texts function code
    APPEND ls_bdc TO lt_bdc.

    " Call XD02 in display mode — MODE 'E' shows screens to user
    CALL TRANSACTION c_tcode_xd02
    USING lt_bdc
    MODE c_mode
    UPDATE c_s.

  ENDMETHOD.

  METHOD handle_toolbar.

    DATA ls_button TYPE stb_button.
    CLEAR ls_button.
    ls_button-function = c_fcode_download.
    ls_button-butn_type = 0.
    APPEND ls_button TO e_object->mt_toolbar.

  ENDMETHOD.

  METHOD handle_user_command.
    CASE e_ucomm.
      WHEN c_fcode_download.
        PERFORM download_data.
    ENDCASE.
  ENDMETHOD.

ENDCLASS.

*=====================================================================*
* SCREEN 100 MODULES
*=====================================================================*

MODULE status_0100 OUTPUT.
  SET PF-STATUS c_pf_status.

  SET TITLEBAR c_titlebar.

  CLEAR gs_layout.
  gs_layout-no_toolbar = abap_true. " hides alv grid internal toolbar

  IF go_container IS INITIAL.

    CREATE OBJECT go_container
      EXPORTING
        container_name = c_container.

    CREATE OBJECT go_grid
      EXPORTING
        i_parent = go_container.

    " Store ALV object globally so handler stays alive after module exits
    go_alv_obj = NEW lcl_alv( ).
    go_alv_obj->build_fcat( ).

    " Register hotspot handler on the global object (not a local variable)
    SET HANDLER go_alv_obj->handle_hotspot_click FOR go_grid.
    SET HANDLER go_alv_obj->handle_toolbar FOR go_grid.
    SET HANDLER go_alv_obj->handle_user_command FOR go_grid.

    CALL METHOD go_grid->set_table_for_first_display
      EXPORTING
        is_layout       = gs_layout
        i_save          = c_save_layout
      CHANGING
        it_outtab       = gy_output
        it_fieldcatalog = go_alv_obj->gt_fcat
      EXCEPTIONS
        OTHERS          = 4.

    CALL METHOD go_grid->set_toolbar_interactive.

  ENDIF.

ENDMODULE.

MODULE user_command_0100 INPUT.
  CASE sy-ucomm.
    WHEN c_fcode_back OR c_fcode_exit OR c_fcode_cancel.
      LEAVE TO SCREEN 0.
  ENDCASE.
ENDMODULE.

*&---------------------------------------------------------------------*
*& Form DOWNLOAD_DATA
*& Uses GUI_FILE_SAVE_DIALOG so user picks path (not hardcoded)
*&---------------------------------------------------------------------*
FORM download_data.
  DATA: lv_file    TYPE string,
        lv_default TYPE string.

  " Default filename with timestamp
  CONCATENATE c_file_prefix sy-datum+4(4) c_file_ext
  INTO lv_default.

  " Let user choose save location (fixes hardcoded C:\temp bug)
  CALL FUNCTION 'GUI_FILE_SAVE_DIALOG'
    EXPORTING
      window_title      = text-010
      default_file_name = lv_default
    IMPORTING
      filename          = lv_file
    EXCEPTIONS
      OTHERS            = 1.

  CHECK lv_file IS NOT INITIAL.

  CALL FUNCTION 'GUI_DOWNLOAD'
    EXPORTING
      filename              = lv_file
      filetype              = c_filetype
      write_field_separator = c_separator
    TABLES
      data_tab              = gy_output
    EXCEPTIONS
      OTHERS                = 1.

  IF sy-subrc = 0.
    MESSAGE s039(zprd).
  ELSE.
    MESSAGE s235(zprd) DISPLAY LIKE c_mode.
  ENDIF.

ENDFORM.

Program Overview
This report program displays and exports customer master text data. It reads customer texts from SAP (KNA1 / STXH / TLINE), displays them in an ALV grid with one output row per text line, and allows the user to download the results or navigate directly to XD02 to view or edit a customer's texts.
Includes
ZLSD_RPT10243_TOP – This include contains global type definitions, data declarations, constants, and class definitions.
•	Defines output structure ty_output with fields KUNNR, NAME1, TDID, TDTEXT, SPRAS, TDLINE — one row per text line as per FDS requirement.
•	Declares global output table gy_output and work area gs_output used across all includes.
•	Defines all constants: object/table names, BDC field names and ok-codes for XD02 navigation, file type and naming defaults, ALV container name and field names.
•	Declares class lcl_alv with methods: build_fcat, handle_hotspot_click, handle_toolbar, handle_user_command.
•	Declares class lcl_main with method: run.

ZLSD_RPT10243_SEL – This include contains the selection screen definition. All fields are currently commented out and reserved for future use. Planned fields: S_KUNNR (Customer Number), P_VKORG (Sales Org, mandatory), S_TDID (Text ID, mandatory).

ZLSD_RPT10243_F01 – This include contains all class implementations (lcl_main and lcl_alv), screen 100 modules, the DOWNLOAD_DATA form, and global screen object declarations (go_container, go_grid, go_alv_obj, gs_layout).
START-OF-SELECTION
Instantiates lcl_main and calls its run( ) method to fetch and populate the global output table. Then calls CALL SCREEN 100 to render the ALV grid.
Class: lcl_main
Methods:
•	RUN – Main execution method. Fetches customer text data and populates gy_output.
-	Joins KNA1, KNVV, and STXH to get all customer text headers for Sales Org 1000, filtered by current logon language.
-	Fetches text ID descriptions from TTXIT for each TDID found.
-	Calls FM READ_TEXT for each customer and text type to retrieve actual text lines from TLINE.
-	Builds one output row per non-empty TDLINE. Customer and header fields (KUNNR, NAME1, TDID, TDTEXT) are populated only on the first line of each text block.
-	Returns without output and issues an info message if no data is found.
Class: lcl_alv
Methods:
•	BUILD_FCAT – Builds the ALV field catalog. Defines six output columns: KUNNR (hotspot-enabled and key-frozen), NAME1, TDID, TDTEXT, SPRAS, and TDLINE. Column labels come from text symbols; output lengths are fixed per column.
•	HANDLE_HOTSPOT_CLICK – Fires when the user clicks a KUNNR cell. Reads the customer number from the clicked row and launches transaction XD02 via BDC, navigating automatically to the Texts screen (Extras > Texts) for that customer.
•	HANDLE_TOOLBAR – Adds a custom Download button to the ALV toolbar using function code DOWNLOAD.
•	HANDLE_USER_COMMAND – Handles the Download button click event and calls form DOWNLOAD_DATA.
Screen 100 Modules
•	STATUS_0100 (OUTPUT) – Sets PF-status and title bar. On first call: creates the custom container and ALV grid object, registers event handlers for hotspot, toolbar, and user command, displays gy_output via set_table_for_first_display, and activates the interactive toolbar.
•	USER_COMMAND_0100 (INPUT) – Handles BACK, EXIT, and CANCEL function codes by leaving to screen 0.
Form: DOWNLOAD_DATA
Opens a Save File dialog (GUI_FILE_SAVE_DIALOG) with a default filename built from the prefix 'customer_texts_' plus the current date plus '.txt'. If the user confirms a path, calls GUI_DOWNLOAD to write gy_output as an ASCII tab-separated file. Displays a success or error message based on the return code.


Start
Instantiate lcl_main → call run( )
Main class is created and the run method is triggered
to begin data collection.
Join KNA1 / KNVV / STXH
Fetches customer text headers for Sales Org 1000,
filtered by current logon language.
Check Data Found
If no records returned, show info message
and exit. Otherwise continue.
Fetch Text Descriptions (TTXIT)
Retrieves text ID descriptions for each TDID
found, filtered by language.
Call FM READ_TEXT — Build Output
Loops through each customer and text type, reads
TLINE content, builds one row per text line.
Display ALV Grid (Screen 100)
Creates container and ALV grid, registers event
handlers, displays gy_output with field catalog.
User Action — Download or Navigate
Download button exports file via GUI_DOWNLOAD.
KUNNR click opens XD02 Texts via BDC.
Exit — BACK / EXIT / CANCEL
Leaves to screen 0 and ends execution.
Stop
