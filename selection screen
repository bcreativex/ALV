"----------------------------------------------------------------------
" Block 1 — Customer Number
"----------------------------------------------------------------------
SELECTION-SCREEN BEGIN OF BLOCK b1 WITH FRAME TITLE text-001.
  SELECT-OPTIONS s_kunnr FOR kna1-kunnr.          " Customer Number
SELECTION-SCREEN END OF BLOCK b1.

"----------------------------------------------------------------------
" Block 2 — Selection Criteria
"----------------------------------------------------------------------
SELECTION-SCREEN BEGIN OF BLOCK b2 WITH FRAME TITLE text-002.
  SELECT-OPTIONS s_vkorg FOR knvv-vkorg OBLIGATORY NO INTERVALS. " Sales Org
  SELECT-OPTIONS s_ktokd FOR kna1-ktokd.          " Account Group
  SELECT-OPTIONS s_brsch FOR kna1-brsch.          " Industry
  SELECT-OPTIONS s_sortl FOR kna1-sortl.          " Search Term
SELECTION-SCREEN END OF BLOCK b2.

"----------------------------------------------------------------------
" Block 3 — Text Selection
"----------------------------------------------------------------------
SELECTION-SCREEN BEGIN OF BLOCK b3 WITH FRAME TITLE text-003.
  SELECT-OPTIONS s_tdid FOR stxh-tdid OBLIGATORY. " Text ID
SELECTION-SCREEN END OF BLOCK b3.

"----------------------------------------------------------------------
" F4 help for Text ID — restricted to KNA1 object
"----------------------------------------------------------------------
AT SELECTION-SCREEN ON VALUE-REQUEST FOR s_tdid-low.
  PERFORM f4_text_id USING 'S_TDID-LOW'.

AT SELECTION-SCREEN ON VALUE-REQUEST FOR s_tdid-high.
  PERFORM f4_text_id USING 'S_TDID-HIGH'.

"----------------------------------------------------------------------
" Validate Sales Org
"----------------------------------------------------------------------
AT SELECTION-SCREEN ON s_vkorg.
  IF s_vkorg[] IS NOT INITIAL.
    SELECT SINGLE vkorg FROM tvko
      INTO @DATA(lv_chk)
      WHERE vkorg = @s_vkorg-low.
    IF sy-subrc <> 0.
      MESSAGE e001(zprd).
    ENDIF.
  ENDIF.

"----------------------------------------------------------------------
" F4 FORM for Text ID
"----------------------------------------------------------------------
FORM f4_text_id USING iv_field TYPE dynfnam.

  TYPES: BEGIN OF ty_ttxit,
           tdid   TYPE tdid,
           tdtext TYPE tdtext,
         END OF ty_ttxit.

  DATA: lt_ttxit  TYPE TABLE OF ty_ttxit,
        lt_return TYPE TABLE OF ddshretval.

  SELECT tdid, tdtext
    INTO CORRESPONDING FIELDS OF TABLE @lt_ttxit
    FROM ttxit
    WHERE tdobject = @c_tdobject
      AND spras    = @sy-langu
    ORDER BY tdid.

  CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
    EXPORTING
      retfield        = 'TDID'
      dynpprog        = sy-repid
      dynpnr          = sy-dynnr
      dynpfld         = iv_field
      value_org       = 'S'
      multiple_choice = abap_true
    TABLES
      value_tab       = lt_ttxit
      return_tab      = lt_return
    EXCEPTIONS
      OTHERS          = 3.

  LOOP AT lt_return INTO DATA(ls_ret).
    APPEND VALUE #(
      sign   = 'I'
      option = 'EQ'
      low    = ls_ret-fieldval ) TO s_tdid.
  ENDLOOP.

ENDFORM.



"----------------------------------------------------------------------
" General validation — runs on every F8
"----------------------------------------------------------------------
AT SELECTION-SCREEN.
  " Sales Org is mandatory — already handled by OBLIGATORY
  " Text ID is mandatory — already handled by OBLIGATORY
  " But add cross-field validation if needed here

"----------------------------------------------------------------------
" Sales Org — validate exists in TVKO
"----------------------------------------------------------------------
AT SELECTION-SCREEN ON s_vkorg.
  IF s_vkorg[] IS NOT INITIAL.
    SELECT SINGLE @abap_true
      INTO @DATA(lv_vkorg_exists)
      FROM tvko
      WHERE vkorg = @s_vkorg-low.
    IF lv_vkorg_exists IS INITIAL.
      MESSAGE e001(zprd) WITH s_vkorg-low.
    ENDIF.
  ENDIF.

"----------------------------------------------------------------------
" Customer Number — validate exists in KNA1 if entered
"----------------------------------------------------------------------
AT SELECTION-SCREEN ON s_kunnr.
  IF s_kunnr[] IS NOT INITIAL.
    SELECT SINGLE @abap_true
      INTO @DATA(lv_kunnr_exists)
      FROM kna1
      WHERE kunnr = @s_kunnr-low.
    IF lv_kunnr_exists IS INITIAL.
      MESSAGE e001(zprd) WITH s_kunnr-low.   " reuse or create new msg
    ENDIF.
  ENDIF.

"----------------------------------------------------------------------
" Account Group — validate exists in T077D if entered
"----------------------------------------------------------------------
AT SELECTION-SCREEN ON p_ktokd.
  IF p_ktokd IS NOT INITIAL.
    SELECT SINGLE @abap_true
      INTO @DATA(lv_ktokd_exists)
      FROM t077d
      WHERE ktokd = @p_ktokd.
    IF lv_ktokd_exists IS INITIAL.
      MESSAGE e001(zprd) WITH p_ktokd.
    ENDIF.
  ENDIF.

"----------------------------------------------------------------------
" Industry — validate exists in T016 if entered
"----------------------------------------------------------------------
AT SELECTION-SCREEN ON p_brsch.
  IF p_brsch IS NOT INITIAL.
    SELECT SINGLE @abap_true
      INTO @DATA(lv_brsch_exists)
      FROM t016
      WHERE brsch = @p_brsch.
    IF lv_brsch_exists IS INITIAL.
      MESSAGE e001(zprd) WITH p_brsch.
    ENDIF.
  ENDIF.

"----------------------------------------------------------------------
" Text ID — validate exists in TTXIT for KNA1 object if entered
"----------------------------------------------------------------------
AT SELECTION-SCREEN ON s_tdid.
  IF s_tdid[] IS NOT INITIAL.
    SELECT SINGLE @abap_true
      INTO @DATA(lv_tdid_exists)
      FROM ttxit
      WHERE tdobject = @c_tdobject
        AND tdid     = @s_tdid-low
        AND tdspras  = @sy-langu.
    IF lv_tdid_exists IS INITIAL.
      MESSAGE e001(zprd) WITH s_tdid-low.
    ENDIF.
  ENDIF.
