METHOD build_header.

    DATA: lv_value TYPE sdydo_text_element.

    " Sales Org
    e_dyndoc_id->add_text(
      text         = text-h01    " e.g. 'Sales Org:'
      sap_style    = cl_dd_area=>strong ).
    CONCATENATE '  ' s_vkorg-low INTO lv_value.
    e_dyndoc_id->add_text( text = lv_value ).
    e_dyndoc_id->new_line( ).

    " Account Group
    e_dyndoc_id->add_text(
      text         = text-h02    " e.g. 'Account Group:'
      sap_style    = cl_dd_area=>strong ).
    CONCATENATE '  ' p_ktokd INTO lv_value.
    e_dyndoc_id->add_text( text = lv_value ).
    e_dyndoc_id->new_line( ).

    " Customer Class
    e_dyndoc_id->add_text(
      text         = text-h03    " e.g. 'Customer Class:'
      sap_style    = cl_dd_area=>strong ).
    CONCATENATE '  ' p_kukla INTO lv_value.
    e_dyndoc_id->add_text( text = lv_value ).
    e_dyndoc_id->new_line( ).

    " Industry
    e_dyndoc_id->add_text(
      text         = text-h04    " e.g. 'Industry Sector:'
      sap_style    = cl_dd_area=>strong ).
    CONCATENATE '  ' p_brsch INTO lv_value.
    e_dyndoc_id->add_text( text = lv_value ).
    e_dyndoc_id->new_line( ).

    e_dyndoc_id->display_document(
      parent             = go_container
      reuse_layout       = abap_true ).

  ENDMETHOD.

SET HANDLER go_alv_obj->build_header FOR go_grid.

